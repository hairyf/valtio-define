{
  "name": "valtio-define",
  "type": "module",
  "version": "1.0.4",
  "packageManager": "pnpm@10.30.3",
  "description": "⚡quickly create a fully functional and robust Valtio factory",
  "author": "Hairyf <wwu710632@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/hairyf/valtio-define#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hairyf/valtio-define.git"
  },
  "bugs": "https://github.com/hairyf/valtio-define/issues",
  "keywords": [],
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./define": "./src/define.ts",
    "./plugin": "./src/plugin.ts",
    "./plugins": "./src/plugins/index.ts",
    "./plugins/presist": "./src/plugins/presist/index.ts",
    "./types": "./src/types/index.ts",
    "./use": "./src/use.ts",
    "./utils": "./src/utils.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint",
    "prepublishOnly": "nr build",
    "release": "bumpp",
    "start": "tsx src/index.ts",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc",
    "prepare": "simple-git-hooks"
  },
  "peerDependencies": {
    "react": "^18.2.0"
  },
  "dependencies": {
    "@hairy/utils": "catalog:",
    "destr": "catalog:",
    "structure-id": "catalog:",
    "valtio": "catalog:"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:cli",
    "@antfu/ni": "catalog:cli",
    "@antfu/utils": "catalog:inlined",
    "@types/node": "catalog:types",
    "@types/react": "catalog:types",
    "@types/react-dom": "catalog:types",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/browser-playwright": "catalog:testing",
    "@vitest/coverage-v8": "catalog:testing",
    "bumpp": "catalog:cli",
    "eslint": "catalog:cli",
    "lint-staged": "catalog:cli",
    "playwright": "catalog:testing",
    "react": "catalog:",
    "react-dom": "catalog:",
    "simple-git-hooks": "catalog:cli",
    "tinyexec": "catalog:testing",
    "tsdown": "catalog:cli",
    "tsx": "catalog:cli",
    "typescript": "catalog:cli",
    "vite": "catalog:cli",
    "vitest": "catalog:testing",
    "vitest-browser-react": "catalog:testing",
    "vitest-package-exports": "catalog:testing",
    "yaml": "catalog:testing"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm i --frozen-lockfile --ignore-scripts --offline && npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./define": "./dist/define.mjs",
      "./plugin": "./dist/plugin.mjs",
      "./plugins": "./dist/plugins/index.mjs",
      "./plugins/presist": "./dist/plugins/presist/index.mjs",
      "./types": "./dist/types/index.mjs",
      "./use": "./dist/use.mjs",
      "./utils": "./dist/utils.mjs",
      "./package.json": "./package.json"
    }
  }
}
